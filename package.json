{
  "name": "pixelink-root",
  "version": "1.0.0",
  "description": "Pixelink - Transparent PNG Marketplace Platform",
  "main": "server/server.js",
  "scripts": {
    "postinstall": "npm run install-server && npm run install-client",
    "install-all": "npm install && npm run install-server && npm run install-client",
    "install-server": "npm --prefix server install",
    "install-client": "npm --prefix client install --legacy-peer-deps",
    "dev": "concurrently \"npm run dev-server\" \"npm run dev-client\"",
    "dev-server": "npm --prefix server run dev",
    "dev-client": "npm --prefix client run dev",
    "seed": "npm --prefix server run seed",
    "start": "npm --prefix server start",
    "build-client": "npm --prefix client run build"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
